function do_refresh() {
	$('#LookupZone7').html("<p class='text-center px-5'><img src='/assets/img/burger_loading.gif' style='margin:100px auto;'></p>").show();
	$('#LookupZone2').html("<p class='text-center'><img src='/assets/img/beach-gif.gif' style='margin:100px auto;'></p>");
