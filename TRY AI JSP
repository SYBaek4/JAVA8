<%
response.setHeader("Cache-Control","no-cache"); //HTTP 1.1
response.setHeader("Pragma","no-cache"); //HTTP 1.0
response.setDateHeader ("Expires", 0);
//prevents caching at the proxy server
request.setAttribute("hdiUrl", "/");

String pageHREF = request.getRequestURI();
Set<String> roleSet = ub.GetPageRoleSet(pageHREF);

User usr = session.getAttribute("currentSessionUser")!=null ? (User)session.getAttribute("currentSessionUser"): new User() ;

if ( UserBean.hasAccessPage(usr, roleSet)){
	UserBean.accessLogged(usr, pageHREF);
}else{
	response.sendRedirect("/hdi.jsp?err=AccessDenied");
	return;
}


String sDate = request.getParameter("sDate");
String eDate = request.getParameter("eDate");
String addPO = request.getParameter("addPO"); //YES(Additional PO) || NO(N/A)
String upcomingDO = request.getParameter("upcomingDO"); //YES(upcomingDO) || NO(N/A)
String Next_Month = request.getParameter("Next_Month");	//N/A (Default) || 1wk || 2wk || 3wk || 4wk 

//✅ PDESC 다중 선택 파라미터 처리
String[] pdesx = request.getParameterValues("pdesc");
String pdesc_list = (pdesx == null || pdesx.length < 1) ? "QUICKPDESC" : String.join(",", Arrays.asList(pdesx));

//✅ Beans 인스턴스 생성 (옵션 HTML 생성용)
String pdesc_option = wb.make_pdesc_options(pdesc_list);

if( (addPO == null || addPO.isEmpty()) ) {
	addPO = "YES";	
}
if( (upcomingDO == null || upcomingDO.isEmpty()) ) {
	upcomingDO = "YES";	
}
if( (Next_Month == null || Next_Month.isEmpty()) ) {
	Next_Month = "N/A";	
}

String addpo_options="<option value='YES'";
if(addPO.equalsIgnoreCase("YES")) addpo_options+=" selected";
addpo_options+=">Include</option><option value='NO' ";
if(addPO.equalsIgnoreCase("NO")) addpo_options+=" selected";
addpo_options+=">N/A</option>";

String upcomingdo_options="<option value='YES'";
if(upcomingDO.equalsIgnoreCase("YES")) upcomingdo_options+=" selected";
upcomingdo_options+=">Include</option><option value='NO' ";
if(upcomingDO.equalsIgnoreCase("NO")) upcomingdo_options+=" selected";
upcomingdo_options+=">N/A</option>";

//period(sdate, edate)
Calendar cal = Calendar.getInstance();
cal.setTime(new Date());
Date edate = cal.getTime();

Date sdate = DateCalc.FirstdayOftheMonth();
DateFormat df3 = new SimpleDateFormat("MM/dd/yyyy");

if( (sDate != null && !sDate.isEmpty()) && (eDate != null && !eDate.isEmpty()) ) {
	sdate = df3.parse(sDate);
	edate = df3.parse(eDate);
}else{
	eDate = df3.format(edate);	
	sDate = df3.format(sdate);
}
%>
