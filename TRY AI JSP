	$('#LookupZone4').html("<p class='text-center'><img src='/assets/img/truck_white_bg_fast.gif' style='margin:100px auto;'></p>");
	
	$.ajax({
		url: '/part/Part_Room/Parts_WMAPS/WMAPS_WHWIP_Summary_Servlet', 
		data:$("#lookupForm").serialize(),
		type: 'POST',
		dataType: 'json',
		success: function(data) {
			$('#LookupZone7').html(data.report);
		}
	});
	$.ajax({
		url: '/part/Part_Room/Parts_WMAPS/WMAPS_INNOUT_Servlet', 
		data:$("#lookupForm").serialize(),
		type: 'POST',
		dataType: 'json',
		success: function(data) {
			$('#LookupZone2').html(data.report);
		}
	});
	$.ajax({
		url: '/part/Part_Room/Parts_WMAPS/WMAPS_IN_Servlet', 
		data:$("#lookupForm").serialize(),
		type: 'POST',
		dataType: 'json',
		success: function(data) {
			$('#LookupZone3').html(data.report);
		}
	});
	$.ajax({
		url: '/part/Part_Room/Parts_WMAPS/WMAPS_OUT_Servlet', 
		data:$("#lookupForm").serialize(),
		type: 'POST',
		dataType: 'json',
		success: function(data) {
			$('#LookupZone4').html(data.report);
		}
	});
}

