	});
}

// ─────────────────────────────────────────────────────
// ✅ 신규: AI Analysis 함수
// ─────────────────────────────────────────────────────
function do_ai_analyze(type) {
    var btnId = (type === 'WHWIP') ? '#aiBtn_WHWIP' : '#aiBtn_INNOUT';
    var label = (type === 'WHWIP') ? 'WH WIP Summary' : 'IN-N-OUT';

    // 버튼 로딩 상태
    $(btnId).prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Analyzing...');

    // 모달 열고 로딩 표시
    $('#aiModalTitle').text('🤖 AI Analysis - ' + label);
    $('#aiModalBody').html(
        "<div class='text-center py-4'>" +
        "<img src='/assets/img/burger_loading.gif' style='height:80px;'><br>" +
        "<p class='mt-2 text-muted'>AI is analyzing your data...</p>" +
        "</div>"
    );
    $('#aiModal').modal('show');

    $.ajax({
        url:      '/part/Part_Room/Parts_WMAPS/WMAPS_AI_Servlet',
        type:     'GET',
        data:     { type: type },
        dataType: 'json',
        success: function(data) {
            if (data.status === 'SUCCESS') {
                $('#aiModalBody').html("<div class='p-2'>" + data.result + "</div>");
            } else {
                $('#aiModalBody').html(data.result);
            }
        },
        error: function(xhr, status, err) {
            $('#aiModalBody').html(
                "<div class='alert alert-danger'>Request failed: " + err + "</div>"
            );
        },
        complete: function() {
            $(btnId).prop('disabled', false).html('🤖 AI Analysis');
        }
    });
}
</script>
