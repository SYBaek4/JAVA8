## 3-1. jQuery 버전

```javascript
$(document).on('click', '.copy-cell', function () {
    let text = $(this).text().trim();
    let $el  = $(this);

    navigator.clipboard.writeText(text).then(function () {
        $el.addClass('copied');
        setTimeout(function () { $el.removeClass('copied'); }, 1200);
        showCopyToast(text);
    });
});

function showCopyToast(text) {
    let $toast = $('.copy-toast');
    if ($toast.length === 0) $toast = $('<div class="copy-toast">').appendTo('body');
    $toast.text('📋 Copied: ' + text).addClass('show');
    setTimeout(function () { $toast.removeClass('show'); }, 1800);
}
```

